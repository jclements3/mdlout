###########################################################################
#  references_basic - cite two entries from the loutrefs system           #
#  reference database via @Cite; the bibliography is rendered by          #
#  @ReferencesAfterAppendices on the second/third lout pass.              #
###########################################################################

@SysInclude { report }
def @TeX  { @OneCol { T &0.4fo {-0.2f @VShift E} &0.45fo X } }
def @LaTeX { @OneCol { L &0.3fo { +0.1f @VShift 0.8f @Font A } &0.4fo @TeX } }
@SysDatabase @Reference { loutrefs }

@Report
    @Title { References Basic }
    @Author { Tester }
    @InitialLanguage { English }
//

@Section
    @Title { Background }
@Begin
@PP
Knuth's foundational typesetting work @Cite { knuth1984tex } predates the
development of Lout @Cite { kingston1993lout.design } by roughly a decade.
@PP
A different design philosophy is captured in Adobe's PostScript
language @Cite { adobe1990ps }, which Lout ultimately targets as
its primary output back end.
@End @Section
