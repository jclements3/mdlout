# Lout build artifacts
lout/*.o
lout/lout
lout/prg2lout
lout/lout.li
*.li
*.ps
*.pdf

# Python
__pycache__/
*.pyc

# Editor
*.swp
*~

# mydefs is user-specific
mydefs

# WSL alternate-data-stream metadata
*Zone.Identifier

# Lout cross-reference indices written at repo root
lout.lix
*.lix

# Test/build outputs
tests/out/
tests/report.html
tests/visual_diff.html

# examples/out/ holds committed reference renderings.
# Ignore everything by default, then explicitly track curated HTML/PDF
# snapshots so transient/intermediate builds don't pollute the index.
examples/out/*
!examples/out/*.html
!examples/out/*.pdf

# Submodule build artifact (also covered by lout/.gitignore territory,
# but listed here for safety in case the submodule isn't initialized).
lout/doc/user/user.svg

# Stray /tmp-prefixed scratch files (shouldn't end up in-repo, but ignore if they do)
/tmp-*
