# Lout build artifacts
lout/*.o
lout/lout
lout/prg2lout
lout/lout.li
*.li
*.ps
*.pdf

# Python
__pycache__/
*.pyc

# Python packaging build artifacts (pyproject.toml-driven)
dist/
build/
*.egg-info/

# Editor
*.swp
*~

# mydefs is user-specific
mydefs

# WSL alternate-data-stream metadata
*Zone.Identifier

# Lout cross-reference indices written at repo root
lout.lix
*.lix

# Test/build outputs
tests/out/
tests/report.html
tests/visual_diff.html

# tests/history.jsonl is the append-only regression history log (one
# JSON record per run, written by tests/history.py).  tests/history.html
# is the static SVG-chart viewer regenerated alongside it.  Both are
# intentionally tracked so trend lines persist across machines/branches.
!tests/history.jsonl
!tests/history.html

# tests/user_guide_diff/ holds the committed PS-vs-SVG comparison
# evidence (manifests, README, and the 10 worst-page side-by-side
# PNGs). The runner at tests/user_guide_diff.sh regenerates the
# transient intermediates under /tmp/userguide_compare/ -- never into
# the repo -- so we explicitly allow the curated artefacts here in case
# a broader ignore rule is added later.
!tests/user_guide_diff/
!tests/user_guide_diff/README.md
!tests/user_guide_diff/manifest.json
!tests/user_guide_diff/manifest.txt
!tests/user_guide_diff/worst-*.png
# tests/chromium_diff.sh writes its own manifest and worst-NN panels next
# to the rsvg artefacts so both pipelines stay browseable side-by-side.
!tests/user_guide_diff/chromium_manifest.txt
!tests/user_guide_diff/chromium_README.md
!tests/user_guide_diff/chromium/
!tests/user_guide_diff/chromium/worst-*.png

# tests/lout_doc_renders/ holds the committed PS+PDF and SVG+HTML renders
# of all four Lout source documents (design, expert, slides, user). The
# *.pdf/*.html/*.png deliverables and the side-by-side sample galleries
# need to be tracked; transient PS and SVG files live in /tmp/loutdocs.
!tests/lout_doc_renders/
!tests/lout_doc_renders/README.md
!tests/lout_doc_renders/*.html
!tests/lout_doc_renders/*.pdf
!tests/lout_doc_renders/*.sh
!tests/lout_doc_renders/*.py
!tests/lout_doc_renders/*_samples/
!tests/lout_doc_renders/*_samples/*.png

# examples/out/ holds committed reference renderings.
# Ignore everything by default, then explicitly track curated HTML/PDF
# snapshots so transient/intermediate builds don't pollute the index.
# Also track the gallery (index.html + thumb-*.png + preview-*.svg
# heros), regenerated by examples/generate_gallery.py.
examples/out/*
!examples/out/*.html
!examples/out/*.pdf
!examples/out/index.html
!examples/out/thumb-*.png
!examples/out/preview-*.svg

# Submodule build artifact (also covered by lout/.gitignore territory,
# but listed here for safety in case the submodule isn't initialized).
lout/doc/user/user.svg

# Stray /tmp-prefixed scratch files (shouldn't end up in-repo, but ignore if they do)
/tmp-*
